Grammar

    0 $accept: program $end

    1 program: external_list

    2 external_list: external_list external
    3              | external

    4 external: function_definition
    5         | declaration SEMICOLON

    6 function_definition: type_specifier declarator compound_statement
    7                    | EXTERN type_specifier declarator compound_statement

    8 declaration: type_specifier init_declarator_list_opt

    9 init_declarator_list_opt: init_declarator_list
   10                         | %empty

   11 init_declarator_list: init_declarator
   12                     | init_declarator_list COMMA init_declarator

   13 init_declarator: declarator
   14                | declarator ASSIGN initializer

   15 initializer: assignment_expression

   16 type_specifier: INT
   17               | LONG
   18               | SHORT
   19               | FLOAT
   20               | DOUBLE
   21               | VOID
   22               | CHAR
   23               | STRUCT IDENTIFIER

   24 declarator: pointer_opt direct_declarator

   25 pointer_opt: pointer
   26            | %empty

   27 pointer: MULTIPLY
   28        | MULTIPLY pointer

   29 direct_declarator: IDENTIFIER
   30                  | IDENTIFIER LPAREN parameter_list_opt RPAREN
   31                  | LPAREN declarator RPAREN

   32 parameter_list_opt: parameter_list
   33                   | %empty

   34 parameter_list: parameter_declaration
   35               | parameter_list COMMA parameter_declaration

   36 parameter_declaration: type_specifier declarator

   37 compound_statement: LBRACE block_item_list_opt RBRACE

   38 block_item_list_opt: block_item_list
   39                    | %empty

   40 block_item_list: block_item
   41                | block_item_list block_item

   42 block_item: declaration SEMICOLON
   43           | statement

   44 statement: simple_statement
   45          | compound_statement
   46          | IF LPAREN expression RPAREN statement
   47          | IF LPAREN expression RPAREN statement ELSE statement
   48          | WHILE LPAREN expression RPAREN statement
   49          | DO statement WHILE LPAREN expression RPAREN SEMICOLON
   50          | FOR LPAREN expr_opt SEMICOLON expr_opt SEMICOLON expr_opt RPAREN statement
   51          | SWITCH LPAREN expression RPAREN LBRACE case_sections_opt default_section_opt RBRACE

   52 simple_statement: expr_opt SEMICOLON
   53                 | BREAK SEMICOLON
   54                 | CONTINUE SEMICOLON
   55                 | RETURN expr_opt SEMICOLON

   56 expr_opt: expression
   57         | %empty

   58 case_sections_opt: case_sections
   59                  | %empty

   60 case_sections: case_section
   61              | case_sections case_section

   62 case_section: CASE constant_expression COLON statement_list_opt

   63 default_section_opt: DEFAULT COLON statement_list_opt
   64                    | %empty

   65 statement_list_opt: statement_list
   66                   | %empty

   67 statement_list: statement
   68               | statement_list statement

   69 expression: ambiguous_expression

   70 assignment_expression: ambiguous_expression

   71 constant_expression: ambiguous_expression

   72 ambiguous_expression: unary_expression
   73                     | ambiguous_expression COMMA ambiguous_expression
   74                     | ambiguous_expression ASSIGN ambiguous_expression
   75                     | ambiguous_expression LOGICAL_OR ambiguous_expression
   76                     | ambiguous_expression LOGICAL_AND ambiguous_expression
   77                     | ambiguous_expression BITWISE_OR ambiguous_expression
   78                     | ambiguous_expression BITWISE_XOR ambiguous_expression
   79                     | ambiguous_expression BITWISE_AND ambiguous_expression
   80                     | ambiguous_expression EQUAL ambiguous_expression
   81                     | ambiguous_expression NOT_EQUAL ambiguous_expression
   82                     | ambiguous_expression LESS_THAN ambiguous_expression
   83                     | ambiguous_expression GREATER_THAN ambiguous_expression
   84                     | ambiguous_expression LESS_EQUAL ambiguous_expression
   85                     | ambiguous_expression GREATER_EQUAL ambiguous_expression
   86                     | ambiguous_expression SPACESHIP ambiguous_expression
   87                     | ambiguous_expression PLUS ambiguous_expression
   88                     | ambiguous_expression MINUS ambiguous_expression
   89                     | ambiguous_expression MULTIPLY ambiguous_expression
   90                     | ambiguous_expression DIVIDE ambiguous_expression
   91                     | ambiguous_expression MODULO ambiguous_expression

   92 unary_expression: postfix_expression
   93                 | INCREMENT unary_expression
   94                 | DECREMENT unary_expression
   95                 | PLUS unary_expression
   96                 | MINUS unary_expression
   97                 | BITWISE_NOT unary_expression
   98                 | BITWISE_AND unary_expression
   99                 | MULTIPLY unary_expression
  100                 | SIZEOF unary_expression
  101                 | SIZEOF LPAREN type_specifier RPAREN

  102 postfix_expression: primary_expression
  103                   | postfix_expression LBRACKET expression RBRACKET
  104                   | postfix_expression LPAREN argument_expression_list_opt RPAREN
  105                   | postfix_expression DOT IDENTIFIER
  106                   | postfix_expression ARROW IDENTIFIER
  107                   | postfix_expression INCREMENT
  108                   | postfix_expression DECREMENT

  109 argument_expression_list_opt: argument_expression_list
  110                             | %empty

  111 argument_expression_list: assignment_expression
  112                         | argument_expression_list COMMA assignment_expression

  113 primary_expression: IDENTIFIER
  114                   | constant
  115                   | string_literal_sequence
  116                   | LPAREN expression RPAREN

  117 constant: INTEGER_CONSTANT
  118         | HEX_CONSTANT
  119         | FLOAT_CONSTANT
  120         | CHAR_CONSTANT

  121 string_literal_sequence: STRING_LITERAL
  122                        | string_literal_sequence STRING_LITERAL


