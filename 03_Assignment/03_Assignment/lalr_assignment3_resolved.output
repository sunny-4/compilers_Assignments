Grammar

    0 $accept: program $end

    1 program: external_list

    2 external_list: external_list external
    3              | external

    4 external: function_definition
    5         | declaration SEMICOLON

    6 function_definition: type_specifier declarator compound_statement
    7                    | EXTERN type_specifier declarator compound_statement

    8 declaration: type_specifier init_declarator_list_opt

    9 init_declarator_list_opt: init_declarator_list
   10                         | %empty

   11 init_declarator_list: init_declarator
   12                     | init_declarator_list COMMA init_declarator

   13 init_declarator: declarator
   14                | declarator ASSIGN initializer

   15 initializer: assignment_expression

   16 type_specifier: INT
   17               | LONG
   18               | SHORT
   19               | FLOAT
   20               | DOUBLE
   21               | VOID
   22               | CHAR
   23               | STRUCT IDENTIFIER

   24 declarator: pointer_opt direct_declarator

   25 pointer_opt: pointer
   26            | %empty

   27 pointer: MULTIPLY
   28        | MULTIPLY pointer

   29 direct_declarator: IDENTIFIER
   30                  | IDENTIFIER LPAREN parameter_list_opt RPAREN
   31                  | LPAREN declarator RPAREN

   32 parameter_list_opt: parameter_list
   33                   | %empty

   34 parameter_list: parameter_declaration
   35               | parameter_list COMMA parameter_declaration

   36 parameter_declaration: type_specifier declarator

   37 compound_statement: LBRACE block_item_list_opt RBRACE

   38 block_item_list_opt: block_item_list
   39                    | %empty

   40 block_item_list: block_item
   41                | block_item_list block_item

   42 block_item: declaration SEMICOLON
   43           | statement

   44 statement: simple_statement
   45          | compound_statement
   46          | IF LPAREN expression RPAREN statement
   47          | IF LPAREN expression RPAREN statement ELSE statement
   48          | WHILE LPAREN expression RPAREN statement
   49          | DO statement WHILE LPAREN expression RPAREN SEMICOLON
   50          | FOR LPAREN expr_opt SEMICOLON expr_opt SEMICOLON expr_opt RPAREN statement
   51          | SWITCH LPAREN expression RPAREN LBRACE case_sections_opt default_section_opt RBRACE

   52 simple_statement: expr_opt SEMICOLON
   53                 | BREAK SEMICOLON
   54                 | CONTINUE SEMICOLON
   55                 | RETURN expr_opt SEMICOLON

   56 expr_opt: expression
   57         | %empty

   58 case_sections_opt: case_sections
   59                  | %empty

   60 case_sections: case_section
   61              | case_sections case_section

   62 case_section: CASE constant_expression COLON statement_list_opt

   63 default_section_opt: DEFAULT COLON statement_list_opt
   64                    | %empty

   65 statement_list_opt: statement_list
   66                   | %empty

   67 statement_list: statement
   68               | statement_list statement

   69 expression: assignment_expression
   70           | expression COMMA assignment_expression

   71 assignment_expression: conditional_expression
   72                      | unary_expression ASSIGN assignment_expression

   73 constant_expression: conditional_expression

   74 conditional_expression: logical_or_expression

   75 logical_or_expression: logical_and_expression
   76                      | logical_or_expression LOGICAL_OR logical_and_expression

   77 logical_and_expression: bitwise_or_expression
   78                       | logical_and_expression LOGICAL_AND bitwise_or_expression

   79 bitwise_or_expression: bitwise_xor_expression
   80                      | bitwise_or_expression BITWISE_OR bitwise_xor_expression

   81 bitwise_xor_expression: bitwise_and_expression
   82                       | bitwise_xor_expression BITWISE_XOR bitwise_and_expression

   83 bitwise_and_expression: equality_expression
   84                       | bitwise_and_expression BITWISE_AND equality_expression

   85 equality_expression: relational_expression
   86                    | equality_expression EQUAL relational_expression
   87                    | equality_expression NOT_EQUAL relational_expression

   88 relational_expression: additive_expression
   89                      | relational_expression LESS_THAN additive_expression
   90                      | relational_expression GREATER_THAN additive_expression
   91                      | relational_expression LESS_EQUAL additive_expression
   92                      | relational_expression GREATER_EQUAL additive_expression
   93                      | relational_expression SPACESHIP additive_expression

   94 additive_expression: multiplicative_expression
   95                    | additive_expression PLUS multiplicative_expression
   96                    | additive_expression MINUS multiplicative_expression

   97 multiplicative_expression: unary_expression
   98                          | multiplicative_expression MULTIPLY unary_expression
   99                          | multiplicative_expression DIVIDE unary_expression
  100                          | multiplicative_expression MODULO unary_expression

  101 unary_expression: postfix_expression
  102                 | INCREMENT unary_expression
  103                 | DECREMENT unary_expression
  104                 | PLUS unary_expression
  105                 | MINUS unary_expression
  106                 | BITWISE_NOT unary_expression
  107                 | BITWISE_AND unary_expression
  108                 | MULTIPLY unary_expression
  109                 | SIZEOF unary_expression
  110                 | SIZEOF LPAREN type_specifier RPAREN

  111 postfix_expression: primary_expression
  112                   | postfix_expression LBRACKET expression RBRACKET
  113                   | postfix_expression LPAREN argument_expression_list_opt RPAREN
  114                   | postfix_expression DOT IDENTIFIER
  115                   | postfix_expression ARROW IDENTIFIER
  116                   | postfix_expression INCREMENT
  117                   | postfix_expression DECREMENT

  118 argument_expression_list_opt: argument_expression_list
  119                             | %empty

  120 argument_expression_list: assignment_expression
  121                         | argument_expression_list COMMA assignment_expression

  122 primary_expression: IDENTIFIER
  123                   | constant
  124                   | string_literal_sequence
  125                   | LPAREN expression RPAREN

  126 constant: INTEGER_CONSTANT
  127         | HEX_CONSTANT
  128         | FLOAT_CONSTANT
  129         | CHAR_CONSTANT

  130 string_literal_sequence: STRING_LITERAL
  131                        | string_literal_sequence STRING_LITERAL


